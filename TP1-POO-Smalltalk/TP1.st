Object subclass: #CentroTransplantes	instanceVariableNames: 'nombre listaPacientes listaDonantes listaEspera evaluador registro compatibilidadesRegistrados compatibilidadesGenerales'	classVariableNames: ''	package: 'TP1'!!CentroTransplantes methodsFor: 'as yet unclassified'!verificarDonanteRegistrado: unDonante(listaDonantes  includes: unDonante ) ifFalse: [ 	self error: 'El donante no está registrado en el centro' ].! !!CentroTransplantes methodsFor: 'as yet unclassified' stamp: 'Ema 10/5/2025 16:16'!compatibilidad: unPaciente con: unDonante|resultado|evaluador ifNil:[self error: 'No hay evaluador de compatibilidad definido.'].resultado := evaluador compatibilidadPaciente: unPaciente con: unDonante.self registro add: resultado.^resultado! !!CentroTransplantes methodsFor: 'as yet unclassified' stamp: 'Ema 10/5/2025 16:18'!calculaCompatibilidadesGeneral|listaCompatibilidades|listaCompatibilidades := OrderedCollection new.self listaPacientes do: [ :paciente |        self listaDonantes do: [ :donante |            listaCompatibilidades add: (self compatibilidadSinRegistro: paciente con: donante)        ]    ].compatibilidadesGenerales := listaCompatibilidades! !!CentroTransplantes methodsFor: 'as yet unclassified' stamp: 'Ema 10/5/2025 15:53'!verificarPacienteRegistrado: unPaciente(listaPacientes includes: unPaciente ) ifFalse: [ 	self error: 'El paciente no está registrado en el centro' ].! !!CentroTransplantes methodsFor: 'as yet unclassified'!donanteDePaciente: unPaciente^unPaciente donanteRegistrado ! !!CentroTransplantes methodsFor: 'as yet unclassified' stamp: 'Ema 10/5/2025 16:18'!compatibilidadSinRegistro: unPaciente con: unDonante|resultado|evaluador ifNil:[self error: 'No hay evaluador de compatibilidad definido.'].resultado := evaluador compatibilidadPaciente: unPaciente con: unDonante.^resultado! !!CentroTransplantes methodsFor: 'as yet unclassified'!agregaDonante: unaPersona(listaDonantes anySatisfy: [:d | d dni = unaPersona dni]) ifTrue: [ 	^self error: 'Ya existe un donante con el DNI ', unaPersona dni asString ].listaDonantes add: unaPersona.! !!CentroTransplantes methodsFor: 'as yet unclassified'!inicializarCentroConNombre: unNombreDeCentronombre := unNombreDeCentro.listaDonantes := OrderedCollection new.listaPacientes := OrderedCollection new.listaEspera := Dictionary new."Falta Evaluador aún"^self! !!CentroTransplantes methodsFor: 'as yet unclassified'!agregaPaciente: unaPersona fechaIngreso: unaFecha(listaPacientes anySatisfy: [:p | p dni = unaPersona dni]) ifTrue: [ 	^self error: 'Ya existe un paciente con el DNI ', unaPersona dni asString ].listaPacientes add: unaPersona.listaEspera at: unaPersona dni put: unaFecha.! !!CentroTransplantes methodsFor: 'as yet unclassified'!evaluadorCompatibilidad^evaluador! !!CentroTransplantes methodsFor: 'as yet unclassified'!verificarAsociacionesPrevias: unPaciente con: unDonanteunPaciente donanteRegistrado ifNotNil: [ 	self error: 'El paciente ya tiene un donante registrado' ].unDonante pacienteAsociado ifNotNil:[ 	self error: 'El donante ya está asociado a otro paciente' ].unPaciente = unDonante ifTrue: [ 	self error: 'Una persona no puede ser donante de si misma' ].! !!CentroTransplantes methodsFor: 'as yet unclassified' stamp: 'Ema 10/5/2025 11:46'!guardaRegistros: prefijoNombreArchivo| archivo ruta mesesEspera listaRegistroCompatibles|listaRegistroCompatibles := compatibilidadesGenerales select:[ :r | r compatible ].	"Definir la ruta y crear el archivo"ruta := FileLocator imageDirectory / prefijoNombreArchivo , '_pacientes.csv'.archivo := ruta writeStream.	"Cabecera CSV"archivo nextPutAll: 'PACIENTES'; cr."Recorrer los pacientes"listaPacientes do: [:p |	mesesEspera :=  ((Date today - (listaEspera at: p dni))days/30)floor.	archivo	nextPutAll: 'DNI: '; 	nextPutAll: p dni asString; nextPutAll: ', ';	nextPutAll: 'Nombre: '; 	nextPutAll: p nombre; nextPutAll: ', ';	nextPutAll: 'Apellido: '; 	nextPutAll: p apellido; nextPutAll: ', ';	nextPutAll: 'Meses de espera: ';	nextPutAll: mesesEspera asString; cr.].    archivo close.ruta := FileLocator imageDirectory / prefijoNombreArchivo , '_donantes.csv'.archivo := ruta writeStream.	"Cabecera CSV"archivo nextPutAll: 'DONANTES'; cr."Recorrer los pacientes"listaDonantes do: [:p |	archivo	nextPutAll: 'DNI: '; 	nextPutAll: p dni asString; nextPutAll: ', ';	nextPutAll: 'Nombre: '; 	nextPutAll: p nombre; nextPutAll: ', ';	nextPutAll: 'Apellido: '; 	nextPutAll: p apellido; nextPutAll: ', ';	nextPutAll: 'DNI_Paciente_Asociado: ';	nextPutAll: p pacienteAsociado dni asString; cr.].    archivo close.ruta := FileLocator imageDirectory / prefijoNombreArchivo , '_compatibilidades.csv'.archivo := ruta writeStream.	"Cabecera CSV"archivo nextPutAll: 'COMPATIBILIDADES'; cr."Recorrer los pacientes"listaRegistroCompatibles  do: [ :r |		archivo	nextPutAll: 'DNI_Del_Paciente: '; 	nextPutAll: r paciente dni asString; nextPutAll: ', ';	nextPutAll: 'DNI_Del_Donante: '; 	nextPutAll: r donante dni asString; nextPutAll: ', ';	nextPutAll: 'Porcentaje_Compatibilidad: '; 	nextPutAll: r porcentajeCompatibilidad asString ; cr.].    archivo close.! !!CentroTransplantes methodsFor: 'as yet unclassified' stamp: 'Ema 10/5/2025 11:41'!evaluadorCompatibilidad: unEvaluadorCompatibilidad    evaluador := unEvaluadorCompatibilidad.	self registro ifNil: [ self registro: OrderedCollection new ] ifNotNil: [ self registro removeAll ].! !!CentroTransplantes methodsFor: 'as yet unclassified' stamp: 'Ema 10/5/2025 14:51'!asociaPaciente: unPaciente conDonante: unDonante(self listaPacientes includes: unDonante) ifTrue:[	self error: 'Error: no se puede asociar un paciente con otro paciente'].self verificarPacienteRegistrado: unPaciente.self verificarDonanteRegistrado: unDonante.self verificarAsociacionesPrevias: unPaciente con: unDonante.unPaciente donanteRegistrado: unDonante.unDonante pacienteAsociado: unPaciente.! !!CentroTransplantes methodsFor: 'as yet unclassified' stamp: 'Ema 10/5/2025 16:18'!calculaCompatibilidadesRegistrados|listaCompatibilidades|listaCompatibilidades := OrderedCollection new."listaCompatibilidades := self listaPacientes select: [ :paciente | (self compatibilidad: paciente con: paciente donanteRegistrado)isNotNil and: (paciente donanteRegistrado isNotNil)]."listaPacientes do: [ :p | 	(p donanteRegistrado isNotNil)ifTrue: [		listaCompatibilidades add: (self compatibilidadSinRegistro: p con: p donanteRegistrado)		].	].compatibilidadesRegistrados := listaCompatibilidades! !!CentroTransplantes methodsFor: 'accessing' stamp: 'Ema 10/5/2025 15:22'!compatibilidadesGenerales^compatibilidadesGenerales! !!CentroTransplantes methodsFor: 'accessing' stamp: 'tumama 10/4/2025 18:28'!registro^registro.! !!CentroTransplantes methodsFor: 'accessing'!listaDonantes^listaDonantes! !!CentroTransplantes methodsFor: 'accessing' stamp: 'Ema 10/4/2025 19:27'!registro: unaRutaregistro:= unaRuta  .! !!CentroTransplantes methodsFor: 'accessing' stamp: 'Ema 10/5/2025 15:22'!compatibilidadesRegistrados^compatibilidadesRegistrados! !!CentroTransplantes methodsFor: 'accessing'!listaPacientes^listaPacientes! !"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!CentroTransplantes class	instanceVariableNames: ''!!CentroTransplantes class methodsFor: 'as yet unclassified'!conNombre: unNombreDeCentro|instanciaCentro|instanciaCentro  := super new.instanciaCentro inicializarCentroConNombre: unNombreDeCentro.^instanciaCentro.! !Object subclass: #Criterio	instanceVariableNames: 'nombre resultado'	classVariableNames: ''	package: 'TP1'!!Criterio methodsFor: 'as yet unclassified'!estudiosFaltantes: unPaciente con: unDonanteself subclassResponsibility! !!Criterio methodsFor: 'as yet unclassified'!nombreCriterio^nombre! !!Criterio methodsFor: 'as yet unclassified'!nombreCriterio: unNombrenombre := unNombre! !!Criterio methodsFor: 'as yet unclassified'!evaluarCompatibilidad: unPaciente con: unDonanteself subclassResponsibility! !"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!Criterio class	instanceVariableNames: ''!!Criterio class methodsFor: 'as yet unclassified'!conNombre: unNombre^super new nombreCriterio: unNombre; yourself.! !Criterio subclass: #CriterioDeseable	instanceVariableNames: 'ponderacion'	classVariableNames: ''	package: 'TP1'!!CriterioDeseable methodsFor: 'as yet unclassified'!inicializaCriterioDeseable^self! !!CriterioDeseable methodsFor: 'accessing'!ponderacion: unaPonderacionponderacion := unaPonderacion! !!CriterioDeseable methodsFor: 'accessing'!ponderacion^ponderacion! !"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!CriterioDeseable class	instanceVariableNames: ''!!CriterioDeseable class methodsFor: 'as yet unclassified'!conNombre: unNombre    ^ super conNombre: unNombre.! !CriterioDeseable subclass: #CriterioEdad	instanceVariableNames: ''	classVariableNames: ''	package: 'TP1'!!CriterioEdad methodsFor: 'as yet unclassified'!estudiosFaltantes: unPaciente con: unDonante|listaVacia|listaVacia := OrderedCollection new.^listaVacia.! !!CriterioEdad methodsFor: 'as yet unclassified'!evaluarCompatibilidad: unPaciente con: unDonante|diferencia porcentaje|diferencia := (unPaciente edad - unDonante edad) abs.(diferencia > 30) ifTrue: [ porcentaje := 0 ] ifFalse: [ porcentaje := ((1 - (diferencia / 30)) max: 0) * 100 ].^porcentaje.! !"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!CriterioEdad class	instanceVariableNames: ''!!CriterioEdad class methodsFor: 'instance creation'!new|instancia|instancia := super conNombre: 'Edad'.^instancia.! !CriterioDeseable subclass: #CriterioHLA	instanceVariableNames: ''	classVariableNames: ''	package: 'TP1'!!CriterioHLA methodsFor: 'as yet unclassified'!estudiosFaltantes: unPaciente con: unDonante|estudiosFaltantes|estudiosFaltantes := OrderedCollection  new.(unPaciente obtenerEstudioRealizado: EstudioTipificacionHLA ) ifNil: [ 	estudiosFaltantes add: 'Estudio Tipificacion HLA (Paciente)' ].(unDonante obtenerEstudioRealizado: EstudioTipificacionHLA ) ifNil: [ 	estudiosFaltantes add: 'Estudio Tipificacion HLA (Donante)' ].^estudiosFaltantes ! !!CriterioHLA methodsFor: 'as yet unclassified'!evaluarCompatibilidad: unPaciente con: unDonante|nroMatch porcentaje resultadoEstudioPaciente resultadoEstudioDonante|nroMatch := 0.resultadoEstudioPaciente := unPaciente listaEstudiosClinicos detect: [ :estudio | estudio class = EstudioTipificacionHLA ].resultadoEstudioDonante := unDonante listaEstudiosClinicos detect: [ :estudio | estudio class = EstudioTipificacionHLA ].1 to: resultadoEstudioPaciente alelosA size do: [ :i |    1 to: resultadoEstudioDonante alelosA size do: [ :j |        (resultadoEstudioPaciente alelosA at: i)=(resultadoEstudioDonante alelosA at: j)        ifTrue: [ nroMatch := nroMatch +1 ]         ]    ].1 to: resultadoEstudioPaciente alelosB size do: [ :i |    1 to: resultadoEstudioDonante alelosB size do: [ :j |        (resultadoEstudioPaciente alelosB at: i)=(resultadoEstudioDonante alelosB at: j)        ifTrue: [ nroMatch := nroMatch +1 ]         ]    ].1 to: resultadoEstudioPaciente alelosDR size do: [ :i |    1 to: resultadoEstudioDonante alelosDR size do: [ :j |        (resultadoEstudioPaciente alelosDR at: i)=(resultadoEstudioDonante alelosDR at: j)        ifTrue: [ nroMatch := nroMatch +1 ]         ]    ].porcentaje := (nroMatch / 6) * 100.^porcentaje.! !"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!CriterioHLA class	instanceVariableNames: ''!!CriterioHLA class methodsFor: 'instance creation'!new|instancia|instancia := super conNombre: 'HLA'.^instancia! !CriterioDeseable subclass: #CriterioIMC	instanceVariableNames: ''	classVariableNames: ''	package: 'TP1'!!CriterioIMC methodsFor: 'as yet unclassified'!estudiosFaltantes: unPaciente con: unDonante|estudiosFaltantes|estudiosFaltantes := OrderedCollection  new.(unPaciente estatura) ifNil: [ 	estudiosFaltantes add: 'Estatura (Paciente)' ].(unDonante estatura) ifNil: [ 	estudiosFaltantes add: 'Estatura (Donante)' ].(unPaciente peso) ifNil: [ 	estudiosFaltantes add: 'Peso (Paciente)' ].(unDonante peso) ifNil: [ 	estudiosFaltantes add: 'Peso (Donante)' ].^estudiosFaltantes! !!CriterioIMC methodsFor: 'as yet unclassified'!evaluarCompatibilidad: unPaciente con: unDonante|imcPaciente imcDonante diferencia porcentaje|imcPaciente := unPaciente peso / (unPaciente estatura * unPaciente estatura).imcDonante := unDonante peso / (unDonante estatura * unDonante estatura).diferencia := (imcDonante - imcPaciente) abs.porcentaje := ((1 - (diferencia / 10)) max: 0) * 100.^porcentaje.! !"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!CriterioIMC class	instanceVariableNames: ''!!CriterioIMC class methodsFor: 'instance creation'!new|instancia|instancia := super conNombre: 'IMC'.^instancia! !Criterio subclass: #CriterioObligatorio	instanceVariableNames: ''	classVariableNames: ''	package: 'TP1'!!CriterioObligatorio methodsFor: 'as yet unclassified'!estudiosFaltantes: unPaciente con: unDonanteself subclassResponsibility"self subclassResponsibility lo que hace es definir un método abstracto y lo deriva a las subclases de la clase self (en este caso Criterio)"! !!CriterioObligatorio methodsFor: 'as yet unclassified'!inicializaCriterioObligatorio^self! !"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!CriterioObligatorio class	instanceVariableNames: ''!!CriterioObligatorio class methodsFor: 'as yet unclassified'!conNombre: unNombre    ^ super conNombre: unNombre.! !CriterioObligatorio subclass: #CriterioABO	instanceVariableNames: ''	classVariableNames: ''	package: 'TP1'!!CriterioABO methodsFor: 'as yet unclassified'!estudiosFaltantes: unPaciente con: unDonante|estudiosFaltantes|estudiosFaltantes := OrderedCollection  new.(unPaciente obtenerEstudioRealizado: AnalisisDeSangre) ifNil: [ 	estudiosFaltantes add: 'Analisis de Sangre (Paciente)' ].(unDonante obtenerEstudioRealizado: AnalisisDeSangre) ifNil: [ 	estudiosFaltantes add: 'Analisis de Sangre (Donante)' ].^estudiosFaltantes ! !!CriterioABO methodsFor: 'as yet unclassified'!evaluarCompatibilidad: unPaciente con: unDonante|resultadoEvaluacion resultadoAnalisisPaciente resultadoAnalisisDonante|resultadoEvaluacion := #noApto.resultadoAnalisisPaciente := unPaciente listaEstudiosClinicos detect: [ :estudio | estudio class = AnalisisDeSangre ].resultadoAnalisisDonante := unDonante listaEstudiosClinicos detect: [ :estudio | estudio class = AnalisisDeSangre  ].((resultadoAnalisisPaciente grupoSanguineo = resultadoAnalisisDonante grupoSanguineo) or: (resultadoAnalisisPaciente grupoSanguineo = #O or: resultadoAnalisisDonante grupoSanguineo = #O)) ifTrue: [ 	resultadoEvaluacion := #apto ]. "Si ambos tienen el mismo gpo sanguineo o si alguno de los 2 es O, entonces el resultado es #apto"((resultadoAnalisisPaciente grupoSanguineo = #A or: resultadoAnalisisPaciente grupoSanguineo = #B) and: (resultadoAnalisisDonante grupoSanguineo = #AB))ifTrue: [ 	resultadoEvaluacion := #apto ]. "Si el paciente es A o B y el Donante es AB, entonces es apto."((resultadoAnalisisDonante  grupoSanguineo = #A or: resultadoAnalisisDonante grupoSanguineo = #B) and: (resultadoAnalisisPaciente  grupoSanguineo = #AB))ifTrue: [ 	resultadoEvaluacion := #apto ]. ^resultadoEvaluacion! !"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!CriterioABO class	instanceVariableNames: ''!!CriterioABO class methodsFor: 'instance creation'!new    ^ super conNombre: 'Criterio ABO'! !CriterioObligatorio subclass: #CriterioCrossmatch	instanceVariableNames: ''	classVariableNames: ''	package: 'TP1'!!CriterioCrossmatch methodsFor: 'as yet unclassified'!estudiosFaltantes: unPaciente con: unDonante|estudiosFaltantes|estudiosFaltantes := OrderedCollection  new.(unPaciente obtenerEstudioRealizado: EstudioCrossmatch  ) ifNil: [ 	estudiosFaltantes add: 'Estudio Crossmatch (Paciente)' ].(unDonante obtenerEstudioRealizado: EstudioCrossmatch  ) ifNil: [ 	estudiosFaltantes add: 'Estudio  Crossmatch (Donante)' ].^estudiosFaltantes! !!CriterioCrossmatch methodsFor: 'as yet unclassified'!evaluarCompatibilidad: unPaciente con: unDonante|resultadoEvaluacion estudioPaciente estudioDonante|estudioPaciente := unPaciente listaEstudiosClinicos detect: [ :est | est class = EstudioCrossmatch ].estudioDonante := unDonante listaEstudiosClinicos detect: [ :est | est class = EstudioCrossmatch ].(estudioPaciente resultado = #positivo or: estudioDonante resultado = #positivo) ifTrue: [ 	resultadoEvaluacion := #noApto].resultadoEvaluacion := #apto.^resultadoEvaluacion ! !"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!CriterioCrossmatch class	instanceVariableNames: ''!!CriterioCrossmatch class methodsFor: 'instance creation'!new|instancia|instancia := super conNombre: 'Crossmatch'.^instancia! !CriterioObligatorio subclass: #CriterioEstadoClinico	instanceVariableNames: ''	classVariableNames: ''	package: 'TP1'!!CriterioEstadoClinico methodsFor: 'as yet unclassified'!estudiosFaltantes: unPaciente con: unDonante|estudiosFaltantes|estudiosFaltantes := OrderedCollection  new.(unDonante obtenerEstudioRealizado: EstudioAptitudGeneral ) ifNil: [ 	estudiosFaltantes add: 'Estudio Aptitud General (Donante)' ].^estudiosFaltantes! !!CriterioEstadoClinico methodsFor: 'as yet unclassified' stamp: 'Ema 10/5/2025 16:53'!evaluarCompatibilidad: unPaciente con: unDonante|resultadoEvaluacion estudioDonante|resultadoEvaluacion := #apto.estudioDonante := unDonante listaEstudiosClinicos detect: [ :est | est class = EstudioAptitudGeneral ].(estudioDona