as yet unclassified'!inicializarEvaluadorlistaCriteriosObligatorios := OrderedCollection new.listaCriteriosDeseables := OrderedCollection new.^self! !!EvaluadorCompatibilidad methodsFor: 'as yet unclassified' stamp: 'Ema 10/5/2025 12:51'!compatibilidadPaciente: unPaciente con: unDonante|resultado hayNoAptos acumulador sumaPonderaciones estudiosFaltantes fs valorCriterio|estudiosFaltantes := OrderedCollection new.acumulador := 0.sumaPonderaciones := 0.hayNoAptos := false.resultado := ResultadoCompatibilidad new."--- CRITERIOS OBLIGATORIOS ---"listaCriteriosObligatorios do: [ :criterio | "Por cada criterio obligatorio, primero se fija si se cumplen estan los estudios necesarios. Si estan, los evalua. Si no estan, retorna compatibilidad 0."	fs := criterio estudiosFaltantes: unPaciente  con: unDonante.	fs isNotEmpty ifTrue: [ 		estudiosFaltantes addAll: fs.		^resultado paciente: unPaciente  donante: unDonante   porcentaje: 0 estudiosFaltantes: estudiosFaltantes 		 ].	"Si estan los estudios necesarios se evalua, si luego de evaluarse, retorna noApto, entonces se retorna compatibilidad 0."	((criterio evaluarCompatibilidad: unPaciente  con: unDonante) = #noApto) ifTrue: [ 		 ^resultado paciente: unPaciente  donante: unDonante  porcentaje: 0 estudiosFaltantes: estudiosFaltantes].	 ]."--- CRITERIOS DESEABLES ---"listaCriteriosDeseables do: [ :criterio |	"Para cada criterio, se verifica que tenga los estudios necesarios, si no los tiene, no se evalua y se sigue con el próximo. Se agregan los estudios faltantes a estudiosFaltantes y se vacía fs para poder seguir con el resto"	fs := criterio estudiosFaltantes: unPaciente con: unDonante.	fs isNotEmpty ifTrue: [ 		"Si hay estudios faltantes, se agregan a estudiosFaltantes y se vacia para el proximo criterio"		estudiosFaltantes addAll: fs.		fs removeAll.		 ]ifFalse:[ 		"Si está vacía, se evalua el criterio"		"Se suma la ponderacion asociada al criterio"		sumaPonderaciones := sumaPonderacione