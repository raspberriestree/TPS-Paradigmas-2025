Porcentaje) max: 0.^valor! !"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!CriterioPRA class	instanceVariableNames: ''!!CriterioPRA class methodsFor: 'instance creation'!new|instancia|instancia := super conNombre: 'PRA'.^instancia! !CriterioObligatorio subclass: #CriterioSerologia	instanceVariableNames: ''	classVariableNames: ''	package: 'TP1'!!CriterioSerologia methodsFor: 'as yet unclassified'!estudiosFaltantes: unPaciente con: unDonante|estudiosFaltantes|estudiosFaltantes := OrderedCollection  new.(unPaciente obtenerEstudioRealizado: EstudioSerologicoCompleto ) ifNil: [ 	estudiosFaltantes add: 'Estudio Serologico Completo (Paciente)' ].(unDonante obtenerEstudioRealizado: EstudioSerologicoCompleto ) ifNil: [ 	estudiosFaltantes add: 'Estudio Serologico Completo (Donante)' ].^estudiosFaltantes! !!CriterioSerologia methodsFor: 'as yet unclassified'!evaluarCompatibilidad: unPaciente con: unDonante|resultadoEvaluacion estudioPaciente estudioDonante|resultadoEvaluacion := #noApto.estudioPaciente := unPaciente listaEstudiosClinicos detect: [ :est | est class = EstudioSerologicoCompleto ].estudioDonante := unDonante listaEstudiosClinicos detect: [ :est | est class = EstudioSerologicoCompleto ]."Los resultados de los estudios tanto del paciente como del donante deben ser #apto, si no lo son, se retorna #noApto"((estudioDonante resultado = estudioPaciente resultado) and: estudioPaciente resultado = #apto) ifTrue:[resultadoEvaluacion := #apto].^resultadoEvaluacion ! !"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!CriterioSerologia class	instanceVariableNames: ''!!CriterioSerologia class methodsFor: 'instance creation'!new|instancia|instancia := super conNombre: 'Serologia Completa'.^instancia! !Object subclass: #EstudioClinico	instanceVariableNames: 'nombre resultado'	classVariableNames: ''	package: 'TP1'!!EstudioClinico methodsFor: 'accessing'!nombre: unEstudionombre := unEstudio! !!