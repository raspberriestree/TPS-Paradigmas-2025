'From Pharo11.0.0 of 28 July 2025 [Build information: Pharo-11.0.0+build.748.sha.c1646bb55445a5f4ae44303010a02118509c481d (64 Bit)] on 9 November 2025 at 8:04:59.072 pm'!!CentroTransplantes methodsFor: 'as yet unclassified' stamp: 'Ema 11/9/2025 19:45'!guardaBaseDeDatosProlog	| archivo ruta mesesEspera|	"Definir la ruta y crear el archivo .pl con el nombre del centro"	ruta := FileLocator imageDirectory / (self nombre , '.pl').	archivo := ruta writeStream.	archivo nextPutAll: '% Base de datos exportada desde Smalltalk'; cr; cr.	"--------------------------------------------------"	"Pacientes"	archivo nextPutAll: '% Pacientes'; cr.	self listaPacientes do: [:p |		mesesEspera :=  ((Date today - (listaEspera at: p dni))days/30)floor.		archivo			nextPutAll: 'paciente(dni(' , p dni asString , '), nombre("'				, p nombre , '", "' , p apellido , '"), tiempo_espera('				, mesesEspera asString , ')).';			cr	].	archivo cr.	"--------------------------------------------------"	"Donantes"	archivo nextPutAll: '% Donantes'; cr.	self listaDonantes do: [:d |		archivo			nextPutAll: 'donante(dni(' , d dni asString , '), nombre("'				, d nombre , '", "' , d apellido , '"), dni_paciente('				, d pacienteAsociado dni asString , ')).';			cr	].	archivo cr.	"--------------------------------------------------"	"Compatibilidades"	archivo nextPutAll: '% Compatibilidades'; cr.	"Si tus compatibilidades están en compatibilidadesRegistrados, usar esa colección"	self compatibilidadesRegistrados do: [:c |		archivo			nextPutAll: 'compatibilidad(' , c paciente dni asString , ', '				, c donante dni asString , ', '				, c porcentajeCompatibilidad asString , ').';			cr	].	archivo cr.	archivo nextPutAll: 'delta(2.0).'; cr.	archivo close.! !